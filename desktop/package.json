{
  "name": "plumbpro-inventory-desktop",
  "version": "1.0.5",
  "description": "PlumbPro Inventory Desktop Application",
  "main": "dist/main/index.js",
  "author": {
    "name": "PlumbPro",
    "email": "support@plumbpro.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run copy-resources",
    "copy-resources": "cp -r resources dist/",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:mac:fix": "./scripts/build-mac.sh",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder -mwl",
    "release": "npm run build && electron-builder --publish always",
    "release:win": "npm run build && electron-builder --win --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "argparse": "^2.0.1",
    "async": "^3.2.6",
    "builder-util-runtime": "^9.5.1",
    "debug": "^4.4.3",
    "electron-log": "^5.0.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "fs-extra": "^11.3.3",
    "isexe": "^3.1.1",
    "js-yaml": "^4.1.1",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "lru-cache": "^11.2.5",
    "portfinder": "^1.0.32",
    "semver": "^7.7.3",
    "tiny-typed-emitter": "^2.1.0",
    "which": "^6.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.0",
    "@types/node": "^20.10.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.6.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
