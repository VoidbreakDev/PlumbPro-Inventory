{
  "name": "plumbpro-inventory-server",
  "version": "1.0.5",
  "description": "Backend API for PlumbPro Inventory Management System",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "build": "node bundle.cjs",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:compat": "psql \"$DATABASE_URL\" -f src/db/compatibility-bridge-schema.sql",
    "seed": "node src/db/seed.js"
  },
  "keywords": [
    "inventory",
    "plumbing",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.11.3",
    "stripe": "^20.3.0",
    "winston": "^3.19.0"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "qs": "^6.15.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.9",
    "esbuild": "^0.27.2",
    "nodemon": "^3.0.2"
  }
}
