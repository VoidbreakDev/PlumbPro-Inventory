# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plumbpro_inventory
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# OR use DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/plumbpro_inventory

# Server Configuration
PORT=5001
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# Security (Generate strong secrets using: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_min_32_chars
AI_KEYS_ENCRYPTION_SECRET=your_dedicated_ai_keys_encryption_secret_min_32_chars
JWT_EXPIRES_IN=24h

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=PlumbPro Inventory <noreply@plumbpro.com>

# AI Provider Configuration
AI_PROVIDER=auto

# Google Gemini AI (Get key from https://ai.google.dev/)
GEMINI_API_KEY=

# Ollama (Local AI - FREE)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Feature Toggles
ENABLE_NOTIFICATIONS=true

# Feature-Specific AI Providers
AI_PROVIDER_FORECAST=gemini
AI_PROVIDER_SEARCH=ollama
AI_PROVIDER_TEMPLATE=ollama
AI_PROVIDER_ANOMALY=gemini
AI_PROVIDER_PURCHASE_ORDERS=gemini
AI_PROVIDER_INSIGHTS=gemini
AI_PROVIDER_JOB_COMPLETION=ollama

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
