# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plumbpro_inventory
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# AI Provider Configuration
# Default provider: auto, gemini, ollama, openai, anthropic
AI_PROVIDER=auto

# Google Gemini AI (Free tier: 60 req/min)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (Local AI - FREE)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (Paid)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (Paid)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Feature-Specific Provider Overrides (optional)
# Forecasting (default: gemini - needs accuracy)
AI_PROVIDER_FORECAST=gemini

# Natural Language Search (default: ollama - can be local)
AI_PROVIDER_SEARCH=ollama

# Template Generation (default: ollama - can be local)
AI_PROVIDER_TEMPLATE=ollama

# Anomaly Detection (default: gemini - needs accuracy)
AI_PROVIDER_ANOMALY=gemini

# Purchase Orders (default: gemini - needs accuracy)
AI_PROVIDER_PURCHASE_ORDERS=gemini

# Business Insights (default: gemini - best analysis)
AI_PROVIDER_INSIGHTS=gemini

# Job Completion Check (default: ollama - can be local)
AI_PROVIDER_JOB_COMPLETION=ollama

# CORS
CORS_ORIGIN=http://localhost:3000
