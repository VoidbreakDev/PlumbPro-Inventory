# PlumbPro Inventory - Environment Configuration
# Copy this file to .env and fill in your values

###############################################################################
# Database Configuration
###############################################################################

# PostgreSQL Database URL (for production)
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/plumbpro_inventory

# Or use individual variables:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plumbpro_inventory
DB_USER=postgres
DB_PASSWORD=your_secure_password

###############################################################################
# Server Configuration
###############################################################################

# Server port (default: 5001)
PORT=5001

# Node environment
NODE_ENV=production

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session secret
SESSION_SECRET=your-super-secret-session-key-change-this

###############################################################################
# AI Provider Configuration
###############################################################################

# Google Gemini API Key (for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional, for alternative AI provider)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional, for alternative AI provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

###############################################################################
# Email Configuration (for notifications)
###############################################################################

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# From address for emails
EMAIL_FROM=PlumbPro Inventory <noreply@plumbpro.com>

###############################################################################
# External Integrations
###############################################################################

# Xero Accounting Integration
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# Stripe Payment Processing (for customer portal)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

###############################################################################
# Security Configuration
###############################################################################

# Enable/disable user registration
ENABLE_REGISTRATION=true

# Password minimum length
MIN_PASSWORD_LENGTH=8

# Session timeout (in minutes)
SESSION_TIMEOUT=480

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration (in minutes)
LOCKOUT_DURATION=30

###############################################################################
# Backup Configuration
###############################################################################

# Backup directory
BACKUP_DIR=/path/to/backups

# Auto-backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Number of backups to keep
BACKUP_RETENTION_COUNT=7

###############################################################################
# Development Settings (don't use in production)
###############################################################################

# Enable debug logging
DEBUG=false

# Enable SQL query logging
LOG_SQL=false

# Skip migrations (dangerous!)
SKIP_MIGRATIONS=false

###############################################################################
# Desktop App Configuration
###############################################################################

# Auto-update provider (github, generic)
UPDATE_PROVIDER=github

# Update URL (if using generic provider)
UPDATE_URL=https://your-update-server.com/updates

# Enable auto-updates
AUTO_UPDATE_ENABLED=true

# Check for updates on startup
CHECK_FOR_UPDATES_ON_START=true
